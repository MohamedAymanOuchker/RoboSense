# Copy to .env and adjust for your environment. Never commit the real .env.

# --- Database ---
POSTGRES_USER=robosense
POSTGRES_PASSWORD=robosense
POSTGRES_DB=robosense
# Async SQLAlchemy URL used by the backend (host "db" is the compose service name).
DATABASE_URL=postgresql+asyncpg://robosense:robosense@db:5432/robosense

# --- Auth (used from Milestone 2 onward) ---
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-only-change-me-to-a-long-random-secret-min-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- App ---
ENVIRONMENT=development

# --- Frontend (used from Milestone 5 onward) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
